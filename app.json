{
  "expo": {
    "name": "Do Not Click The Button",
    "slug": "do-not-click-the-button",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.donotclickthebutton"
    },
    "android": {
      "package": "com.example.donotclickthebutton",
      "adaptiveIcon": {
        "backgroundColor": "#FFE66D"
      }
    },
    "web": {},
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "comment": "Drop icon.png / splash.png / adaptive-icon.png into ./assets/ and reference them here when ready."
    }
  }
}
